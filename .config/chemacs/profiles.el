;; Chemacs2 profiles — read from ~/.config/chemacs/profiles.el
;; Switch with: emacs --with-profile <name>   (default if omitted)
(("default"  . ((user-emacs-directory . "~/doom-emacs")))
 ("personal" . ((user-emacs-directory . "~/.config/emacs-personal")))
 ("kick"     . ((user-emacs-directory . "~/emacs-kick"))))
