{
  "editor.fontFamily": "MesloLGMDZ Nerd Font Mono",
  "editor.fontSize": 14,
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "workbench.sideBar.location": "left",
  "workbench.editor.enablePreview": false,
  "editor.tabSize": 2,
  "window.nativeTabs": true,
  "workbench.iconTheme": "vscode-icons",
  "vsicons.projectDetection.autoReload": true,
  "files.exclude": {
    "**/node_modules": true
  },
  "vsicons.dontShowNewVersionMessage": true,
  "editor.wordWrapColumn": 120,
  "markdown.preview.lineHeight": 1.1,
  "terminal.integrated.lineHeight": 0,
  "editor.fontLigatures": true,
  "terminal.integrated.fontWeightBold": "400",
  "workbench.fontAliasing": "auto",
  "workbench.statusBar.feedback.visible": false,
  "editor.fontWeight": "normal",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSaveMode": "modifications",
  "cSpell.userWords": [
    "upsert"
  ],
  "sort-imports.on-save": false,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "npm.keybindingsChangedWarningShown": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.nextEditSuggestions.enabled": true,
  "workbench.startupEditor": "none",
  "editor.renderWhitespace": "all",
  "redhat.telemetry.enabled": false,
  "editor.accessibilitySupport": "off",
  "workbench.colorTheme": "Monokai Dimmed",
  "window.autoDetectColorScheme": true,
  "chat.viewSessions.orientation": "stacked",
  "files.autoSave": "afterDelay",
  "editor.formatOnSave": true,
  "chat.agent.maxRequests": 75,
  "workbench.preferredDarkColorTheme": "Atom One Dark",
  "chat.unifiedAgentsBar.enabled": true,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontWeight": "normal",
  "aws.cloudformation.telemetry.enabled": false,
  "aws.telemetry": false
}
